        // DOM元素
        const welcomeSection = document.getElementById('welcome-section');
        const testSection = document.getElementById('test-section');
        const resultSection = document.getElementById('result-section');
        const startTestBtn = document.getElementById('start-test-btn');
        const retakeTestBtn = document.getElementById('retake-test-btn');
        const prevBtn = document.getElementById('prev-btn');
        const nextBtn = document.getElementById('next-btn');
        const questionText = document.getElementById('question-text');
        const optionsContainer = document.getElementById('options-container');
        const currentQuestionSpan = document.getElementById('current-question');
        const totalQuestionsSpan = document.getElementById('total-questions');
        const progressPercentageSpan = document.getElementById('progress-percentage');
        const progressValue = document.getElementById('progress-value');
        const themeToggleBtn = document.getElementById('theme-toggle');

        // 测试状态
        let currentQuestionIndex = 0;
        const userAnswers = [];
        let selectedOption = null;
        let isDarkMode = false;

        // 初始化
        function init() {
            totalQuestionsSpan.textContent = questions.length;
            updateProgress();
            
            // 事件监听
            startTestBtn.addEventListener('click', startTest);
            retakeTestBtn.addEventListener('click', retakeTest);
            prevBtn.addEventListener('click', goToPrevQuestion);
            nextBtn.addEventListener('click', goToNextQuestion);
            themeToggleBtn.addEventListener('click', toggleTheme);
        }

        // 开始测试
        function startTest() {
            welcomeSection.classList.add('hidden');
            testSection.classList.remove('hidden');
            showQuestion(currentQuestionIndex);
            updateProgress();
        }

        // 重新测试
        function retakeTest() {
            currentQuestionIndex = 0;
            userAnswers.length = 0;
            selectedOption = null;
            resultSection.classList.add('hidden');
            testSection.classList.remove('hidden');
            showQuestion(currentQuestionIndex);
            updateProgress();
        }

        // 显示问题
        function showQuestion(index) {
            const question = questions[index];
            questionText.textContent = question.text;
            currentQuestionSpan.textContent = index + 1;
            
            // 清空选项容器
            optionsContainer.innerHTML = '';
            
            // 添加选项
            question.options.forEach(option => {
                const optionBtn = document.createElement('button');
                optionBtn.className = 'option-btn';
                optionBtn.dataset.optionId = option.id;
                
                // 检查是否已经回答过这个问题
                const savedAnswer = userAnswers.find(answer => answer.questionId === question.id);
                if (savedAnswer && savedAnswer.optionId === option.id) {
                    optionBtn.classList.add('selected');
                    selectedOption = option.id;
                }
                
                optionBtn.innerHTML = `
                    <div class="flex items-center">
                        <div class="option-icon">
                            <span>${option.id}</span>
                        </div>
                        <span>${option.text}</span>
                    </div>
                `;
                
                optionBtn.addEventListener('click', () => selectOption(option.id, optionBtn));
                optionsContainer.appendChild(optionBtn);
            });
            
            // 更新导航按钮状态
            updateNavButtons();
        }

        // 选择选项
        function selectOption(optionId, button) {
            // 移除之前选中的选项
            document.querySelectorAll('.option-btn').forEach(btn => {
                btn.classList.remove('selected');
            });
            
            // 选中当前选项
            button.classList.add('selected');
            selectedOption = optionId;
            
            // 启用下一题按钮
            nextBtn.classList.remove('opacity-50', 'cursor-not-allowed');
            nextBtn.disabled = false;
            
            // 保存答案
            const currentQuestion = questions[currentQuestionIndex];
            const existingAnswerIndex = userAnswers.findIndex(answer => answer.questionId === currentQuestion.id);
            
            if (existingAnswerIndex !== -1) {
                userAnswers[existingAnswerIndex].optionId = optionId;
            } else {
                userAnswers.push({
                    questionId: currentQuestion.id,
                    optionId: optionId
                });
            }
        }

        // 前往上一题
        function goToPrevQuestion() {
            if (currentQuestionIndex > 0) {
                currentQuestionIndex--;
                showQuestion(currentQuestionIndex);
                updateProgress();
            }
        }

        // 前往下一题
        function goToNextQuestion() {
            if (currentQuestionIndex < questions.length - 1) {
                currentQuestionIndex++;
                showQuestion(currentQuestionIndex);
                updateProgress();
            } else {
                // 测试完成，显示结果
                calculateResult();
            }
        }

        // 更新导航按钮状态
        function updateNavButtons() {
            // 上一题按钮
            if (currentQuestionIndex === 0) {
                prevBtn.classList.add('opacity-50', 'cursor-not-allowed');
                prevBtn.disabled = true;
            } else {
                prevBtn.classList.remove('opacity-50', 'cursor-not-allowed');
                prevBtn.disabled = false;
            }
            
            // 下一题按钮
            const hasSelectedOption = selectedOption !== null;
            const isLastQuestion = currentQuestionIndex === questions.length - 1;
            
            if (!hasSelectedOption) {
                nextBtn.classList.add('opacity-50', 'cursor-not-allowed');
                nextBtn.disabled = true;
            } else {
                nextBtn.classList.remove('opacity-50', 'cursor-not-allowed');
                nextBtn.disabled = false;
            }
            
            // 更新下一题按钮文本
            nextBtn.querySelector('span').innerHTML = isLastQuestion ? '查看结果' : '下一题<i class="fa fa-arrow-right ml-2"></i>';
        }

        // 更新进度条
        function updateProgress() {
            const progress = ((currentQuestionIndex + 1) / questions.length) * 100;
            progressPercentageSpan.textContent = `${Math.round(progress)}%`;
            progressValue.style.width = `${progress}%`;
        }

        // 计算结果
        function calculateResult() {
            // 计算每个物理学概念的得分
            const scores = {
                "电磁波": 0,
                "量子纠缠": 0,
                "黑洞": 0,
                "相对论": 0,
                "热力学第二定律": 0,
                "暗物质": 0,
                "引力波": 0,
                "量子隧穿": 0,
                "弦理论": 0,
                "混沌理论": 0,
                "反物质": 0,
                "中微子": 0,
                "全息原理": 0,
                "费米悖论": 0,
                "量子引力": 0
            };
            
            // 遍历用户答案，累加得分
            userAnswers.forEach(answer => {
                const question = questions.find(q => q.id === answer.questionId);
                const selectedOption = question.options.find(o => o.id === answer.optionId);
                
                if (selectedOption) {
                    Object.keys(selectedOption.points).forEach(concept => {
                        scores[concept] += selectedOption.points[concept];
                    });
                }
            });
            
            // 找出得分最高的概念
            let maxScore = 0;
            let mainConcept = "";
            
            Object.keys(scores).forEach(concept => {
                if (scores[concept] > maxScore) {
                    maxScore = scores[concept];
                    mainConcept = concept;
                }
            });
            
            // 计算匹配百分比（相对于理论最高分）
            const theoreticalMaxScore = questions.length * 3; // 每道题最高3分
            const matchPercentage = Math.round((maxScore / theoreticalMaxScore) * 100);
            
            // 准备其他匹配概念（按得分降序排列）
            const otherMatches = Object.keys(scores)
                .filter(concept => concept !== mainConcept)
                .sort((a, b) => scores[b] - scores[a])
                .map(concept => ({
                    name: concept,
                    percentage: Math.round((scores[concept] / theoreticalMaxScore) * 100),
                    info: physicsConcepts[concept]
                }));
            
            // 显示结果
            displayResult(mainConcept, matchPercentage, otherMatches);
        }

        // 显示结果
        function displayResult(mainConcept, matchPercentage, otherMatches) {
            testSection.classList.add('hidden');
            resultSection.classList.remove('hidden');
            
            // 填充主要结果
            const conceptInfo = physicsConcepts[mainConcept];
            document.getElementById('result-icon').innerHTML = `<i class="fa ${conceptInfo.icon}"></i>`;
            document.getElementById('result-title').textContent = conceptInfo.title;
            document.getElementById('result-description').textContent = conceptInfo.description;
            document.getElementById('result-match').style.width = `${matchPercentage}%`;
            document.getElementById('result-percentage').textContent = `${matchPercentage}%`;
            
            // 填充详细分析
            document.getElementById('result-details').innerHTML = `
                <p class="mb-4">${conceptInfo.details}</p>
                <div class="flex items-center mt-4">
                    <div class="w-10 h-10 rounded-full bg-blue-100 text-blue-600 flex items-center justify-center mr-3">
                        <i class="fa fa-lightbulb-o"></i>
                    </div>
                    <p class="italic">${conceptInfo.funFact}</p>
                </div>
            `;
            
            // 填充物理学知识
            document.getElementById('physics-info').textContent = conceptInfo.physicsInfo;
            
            // 填充其他匹配
            const otherMatchesContainer = document.getElementById('other-matches');
            otherMatchesContainer.innerHTML = '';
            
            otherMatches.forEach(match => {
                const matchCard = document.createElement('div');
                matchCard.className = 'physics-card bg-gradient-to-br from-gray-50 to-gray-100';
                matchCard.innerHTML = `
                    <div class="flex items-center mb-3">
                        <div class="w-8 h-8 rounded-full bg-gradient-to-r from-primary/20 to-secondary/20 flex items-center justify-center mr-3">
                            <i class="fa ${match.info.icon} text-gradient"></i>
                        </div>
                        <h5 class="font-bold text-lg">${match.name}</h5>
                    </div>
                    <p class="text-sm text-gray-600 mb-3">${match.info.description}</p>
                    <div class="flex items-center">
                        <div class="w-full bg-gray-200 h-2 rounded-full mr-2">
                            <div class="h-full bg-gradient-to-r from-primary/70 to-secondary/70 rounded-full" style="width: ${match.percentage}%"></div>
                        </div>
                        <span class="text-xs font-bold">${match.percentage}%</span>
                    </div>
                `;
                otherMatchesContainer.appendChild(matchCard);
            });
        }

        // 切换主题
        function toggleTheme() {
            isDarkMode = !isDarkMode;
            
            if (isDarkMode) {
                document.body.classList.add('dark');
                document.body.classList.remove('bg-gradient-to-br', 'from-blue-50', 'to-purple-50');
                document.body.classList.add('bg-gray-900');
                themeToggleBtn.innerHTML = '<span class="relative z-10"><i class="fa fa-sun-o mr-2"></i>切换主题</span><div class="reflection"></div>';
            } else {
                document.body.classList.remove('dark');
                document.body.classList.remove('bg-gray-900');
                document.body.classList.add('bg-gradient-to-br', 'from-blue-50', 'to-purple-50');
                themeToggleBtn.innerHTML = '<span class="relative z-10"><i class="fa fa-moon-o mr-2"></i>切换主题</span><div class="reflection"></div>';
            }
        }

        // 初始化应用
        init();
    </script>
